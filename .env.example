# ============================================================
# VIP LUXÚRIA — Variáveis de ambiente (Vercel + Supabase)
# ------------------------------------------------------------
# COMO USAR:
#   1) Copie este arquivo para ".env" e preencha os valores.
#   2) NUNCA suba o ".env" para o Git (já está no .gitignore).
#   3) No deploy, cadastre estas variáveis em:
#        Vercel -> seu projeto -> Settings -> Environment Variables
#
# Observação: site estático puro NÃO lê .env no navegador.
# Estas variáveis passam a valer quando fizermos a migração
# para Supabase (com build/framework ou serverless functions).
# ============================================================

# ---------- Supabase: valores PÚBLICOS ----------
# Podem aparecer no front-end. Pegue em:
#   Supabase -> Project Settings -> API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=cole-aqui-a-anon-public-key

# ---------- Supabase: valor SECRETO ----------
# Chave "mestra" (acesso total). USAR SOMENTE no servidor
# (serverless functions). NÃO usar no navegador e NÃO versionar.
# Cadastre apenas no painel da Vercel, nunca aqui com valor real.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Storage de imagens ----------
# Nome do bucket onde ficarão as fotos dos perfis.
SUPABASE_BUCKET=perfis

# ---------- Admin ----------
# Na migração, o login do painel passa a ser o Supabase Auth.
# Defina o e-mail do administrador autorizado a editar o site.
ADMIN_EMAIL=seu-email@exemplo.com
